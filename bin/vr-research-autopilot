#!/usr/bin/env node
// Bounded decision router for Vibe Research projects.

import path from "node:path";
import process from "node:process";
import {
  formatAutopilotReport,
  formatAutopilotRunReport,
  runResearchAutopilot,
  stepResearchAutopilot,
} from "../src/research/autopilot.js";

function printHelp() {
  process.stdout.write(`vr-research-autopilot

Route the current research state and latest durable review decision into one
bounded next action. This command is conservative: it emits exact next commands
and only mutates safe phase state with --apply.

Usage:
  vr-research-autopilot run <project-dir> [options]
  vr-research-autopilot step <project-dir> [options]
  vr-research-autopilot <project-dir> [options]

Options:
  --apply                  Apply safe phase-state transitions or delegate safe orchestrator applies.
  --decision <action>      Override the latest result-doc review decision for this step.
  --max-steps <N>          Max bounded execution steps for run mode (default: 1).
  --command <text>         Experiment command to include in suggested runner cycle command.
  --metric-regex <regex>   Extract metric from stdout/stderr capture group 1 in run mode.
  --metric <text>          Explicit metric/outcome value for run mode.
  --change <text>          Cycle change description for run mode.
  --qual <text>            One-line qualitative observation for run mode.
  --seed <text>            Seed/id attached to the cycle metric in run mode.
  --cycle-timeout-ms <ms>  Per-cycle command timeout in run mode.
  --agent-review-provider <id>
                           Launch a reviewer coding agent before posting/waiting on a review card.
  --agent-review-name <text>
                           Name for the reviewer agent session.
  --agent-review-prompt <text>
                           Override the reviewer agent prompt.
  --finish-on-synthesize   Let run mode call finishMove when decision is synthesize.
  --finish-apply           Apply README/LOG updates when finishing.
  --finish-takeaway <text> Takeaway to write when finishing.
  --finish-analysis <text> Analysis to write when finishing.
  --finish-decision <text> Decision line to write when finishing.
  --finish-summary <text>  Summary used for LOG/README resolution.
  --finish-score <text>    Score/verdict used when applying admission.
  --finish-cost-compute <N>
                           Compute cost debit to record when finishing.
  --finish-cost-dollars <N>
                           Dollar cost debit to record when finishing.
  --finish-aggregate-metric
                           Aggregate cycle metrics when finishing.
  --finish-metric-name <text>
                           Metric name for finish aggregation.
  --finish-higher-is-better
                           Mark aggregate metric as higher-is-better.
  --finish-lower-is-better Mark aggregate metric as lower-is-better.
  --finish-auto-admit      Run admission while finishing.
  --finish-update-paper    Update paper.md while finishing.
  --finish-publish-canvas  Publish final figure/canvas while finishing.
  --finish-paper-figure <path-or-url>
                           Figure to copy/link into paper.md.
  --finish-paper-caption <text>
                           Caption for the generated paper result section.
  --finish-paper-limitations <text>
                           Limitations sentence for the paper update.
  --finish-paper-discussion <text>
                           Discussion sentence for the paper update.
  --finish-canvas-image <path>
                           Final image to publish to Agent Canvas.
  --finish-canvas-url <url>
                           Final URL to publish to Agent Canvas.
  --finish-canvas-title <text>
                           Agent Canvas title.
  --finish-canvas-caption <text>
                           Agent Canvas caption.
  --finish-canvas-session-id <id>
                           Session id for the final Agent Canvas.
  --finish-canvas-agent-id <id>
                           Agent/provider id for the final Agent Canvas.
  --code-cwd <dir>         Code repo cwd to include in suggested runner command.
  --ask-human              Include human review gates in suggested/delegated commands.
  --wait-human             Wait when delegating to human-reviewable orchestrator actions.
  --timeout-ms <ms>        Total wait budget for --wait-human.
  --api <url>              Agent Town API base URL.
  --allow-cross-version    Allow judge admission across benchmark versions when delegated.
  --no-paper               Skip paper.md linting when delegated to judge/orchestrator.
  --json                   Print the full structured report.
  --help, -h               Show this help.
`);
}

function requireValue(args, index, flag) {
  const value = args[index + 1];
  if (!value || value.startsWith("--")) {
    throw new Error(`${flag} requires a value.`);
  }
  return value;
}

function parseArgs(argv) {
  const opts = {
    allowCrossVersion: false,
    api: "",
    apply: false,
    askHuman: false,
    agentReviewName: "",
    agentReviewPrompt: "",
    agentReviewProvider: "",
    checkPaper: true,
    codeCwd: "",
    commandText: "",
    commandTimeoutMs: 30 * 60 * 1000,
    decision: "",
    finishAggregateMetric: false,
    finishAnalysis: "",
    finishApply: false,
    finishAutoAdmit: false,
    finishCanvasAgentId: "",
    finishCanvasCaption: "",
    finishCanvasImage: "",
    finishCanvasSessionId: "",
    finishCanvasTitle: "",
    finishCanvasUrl: "",
    finishCostCompute: "",
    finishCostDollars: "",
    finishHigherIsBetter: undefined,
    finishMetricName: "",
    finishOnSynthesize: false,
    finishPaperCaption: "",
    finishPaperDiscussion: "",
    finishPaperFigure: "",
    finishPaperLimitations: "",
    finishPublishCanvas: false,
    finishScore: "",
    finishSummary: "",
    finishTakeaway: "",
    finishDecision: "",
    finishUpdatePaper: false,
    change: "",
    help: false,
    json: false,
    maxSteps: 1,
    metric: "",
    metricRegex: "",
    projectDir: "",
    qual: "",
    seed: "",
    subcommand: "step",
    timeoutMs: "",
    waitHuman: false,
  };

  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];
    if (arg === "--help" || arg === "-h") { opts.help = true; continue; }
    if (arg === "--allow-cross-version") { opts.allowCrossVersion = true; continue; }
    if (arg === "--apply") { opts.apply = true; continue; }
    if (arg === "--ask-human") { opts.askHuman = true; continue; }
    if (arg === "--finish-aggregate-metric") { opts.finishAggregateMetric = true; continue; }
    if (arg === "--finish-apply") { opts.finishApply = true; continue; }
    if (arg === "--finish-auto-admit") { opts.finishAutoAdmit = true; continue; }
    if (arg === "--finish-higher-is-better") { opts.finishHigherIsBetter = true; continue; }
    if (arg === "--finish-lower-is-better") { opts.finishHigherIsBetter = false; continue; }
    if (arg === "--finish-on-synthesize") { opts.finishOnSynthesize = true; continue; }
    if (arg === "--finish-publish-canvas") { opts.finishPublishCanvas = true; continue; }
    if (arg === "--finish-update-paper") { opts.finishUpdatePaper = true; continue; }
    if (arg === "--json") { opts.json = true; continue; }
    if (arg === "--no-paper") { opts.checkPaper = false; continue; }
    if (arg === "--wait-human") { opts.askHuman = true; opts.waitHuman = true; continue; }
    if (arg === "--api") { opts.api = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--agent-review-name") { opts.agentReviewName = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--agent-review-prompt") { opts.agentReviewPrompt = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--agent-review-provider") { opts.agentReviewProvider = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--code-cwd") { opts.codeCwd = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--change") { opts.change = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--cycle-timeout-ms") { opts.commandTimeoutMs = Number(requireValue(argv, index, arg)); index += 1; continue; }
    if (arg === "--command") { opts.commandText = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--decision") { opts.decision = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--finish-analysis") { opts.finishAnalysis = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--finish-canvas-agent-id") { opts.finishCanvasAgentId = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--finish-canvas-caption") { opts.finishCanvasCaption = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--finish-canvas-image") { opts.finishCanvasImage = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--finish-canvas-session-id") { opts.finishCanvasSessionId = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--finish-canvas-title") { opts.finishCanvasTitle = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--finish-canvas-url") { opts.finishCanvasUrl = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--finish-cost-compute") { opts.finishCostCompute = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--finish-cost-dollars") { opts.finishCostDollars = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--finish-decision") { opts.finishDecision = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--finish-metric-name") { opts.finishMetricName = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--finish-paper-caption") { opts.finishPaperCaption = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--finish-paper-discussion") { opts.finishPaperDiscussion = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--finish-paper-figure") { opts.finishPaperFigure = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--finish-paper-limitations") { opts.finishPaperLimitations = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--finish-score") { opts.finishScore = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--finish-summary") { opts.finishSummary = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--finish-takeaway") { opts.finishTakeaway = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--max-steps") { opts.maxSteps = Number(requireValue(argv, index, arg)); index += 1; continue; }
    if (arg === "--metric") { opts.metric = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--metric-regex") { opts.metricRegex = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--qual") { opts.qual = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--seed") { opts.seed = requireValue(argv, index, arg); index += 1; continue; }
    if (arg === "--timeout-ms") { opts.timeoutMs = requireValue(argv, index, arg); index += 1; continue; }
    if (arg.startsWith("--")) throw new Error(`unknown flag: ${arg}`);
    if (arg === "run" && opts.subcommand === "step" && !opts.projectDir) { opts.subcommand = "run"; continue; }
    if (arg === "step" && opts.subcommand === "step" && !opts.projectDir) { opts.subcommand = "step"; continue; }
    if (!opts.projectDir) { opts.projectDir = arg; continue; }
    throw new Error(`unexpected positional arg: ${arg}`);
  }
  return opts;
}

async function main() {
  let opts;
  try {
    opts = parseArgs(process.argv.slice(2));
  } catch (error) {
    process.stderr.write(`${error.message}\n\n`);
    printHelp();
    process.exit(2);
  }

  if (opts.help) {
    printHelp();
    return;
  }
  if (!opts.projectDir) {
    throw new Error("project-dir is required.");
  }

  const common = {
    projectDir: path.resolve(opts.projectDir),
    apply: opts.apply,
    decision: opts.decision,
    askHuman: opts.askHuman,
    waitHuman: opts.waitHuman,
    agentTownApi: opts.api,
    timeoutMs: opts.timeoutMs,
    allowCrossVersion: opts.allowCrossVersion,
    checkPaper: opts.checkPaper,
    codeCwd: opts.codeCwd,
    commandText: opts.commandText,
    agentReviewProvider: opts.agentReviewProvider,
    agentReviewName: opts.agentReviewName,
    agentReviewPrompt: opts.agentReviewPrompt,
  };

  const report = opts.subcommand === "run"
    ? await runResearchAutopilot({
      ...common,
      maxSteps: opts.maxSteps,
      commandTimeoutMs: opts.commandTimeoutMs,
      metric: opts.metric,
      metricRegex: opts.metricRegex,
      change: opts.change,
      qual: opts.qual,
      seed: opts.seed,
      finishOnSynthesize: opts.finishOnSynthesize,
      finishApply: opts.finishApply,
      finishTakeaway: opts.finishTakeaway,
      finishAnalysis: opts.finishAnalysis,
      finishDecision: opts.finishDecision,
      finishSummary: opts.finishSummary,
      finishScore: opts.finishScore,
      finishCostCompute: opts.finishCostCompute,
      finishCostDollars: opts.finishCostDollars,
      finishAggregateMetric: opts.finishAggregateMetric,
      finishMetricName: opts.finishMetricName,
      finishHigherIsBetter: opts.finishHigherIsBetter,
      finishAutoAdmit: opts.finishAutoAdmit,
      finishUpdatePaper: opts.finishUpdatePaper,
      finishPublishCanvas: opts.finishPublishCanvas,
      finishPaperFigure: opts.finishPaperFigure,
      finishPaperCaption: opts.finishPaperCaption,
      finishPaperLimitations: opts.finishPaperLimitations,
      finishPaperDiscussion: opts.finishPaperDiscussion,
      finishCanvasImage: opts.finishCanvasImage,
      finishCanvasUrl: opts.finishCanvasUrl,
      finishCanvasTitle: opts.finishCanvasTitle,
      finishCanvasCaption: opts.finishCanvasCaption,
      finishCanvasSessionId: opts.finishCanvasSessionId,
      finishCanvasAgentId: opts.finishCanvasAgentId,
    })
    : await stepResearchAutopilot(common);

  if (opts.json) {
    process.stdout.write(`${JSON.stringify(report, null, 2)}\n`);
  } else {
    process.stdout.write(`${opts.subcommand === "run" ? formatAutopilotRunReport(report) : formatAutopilotReport(report)}\n`);
  }
}

void main().catch((error) => {
  process.stderr.write(`[vr-research-autopilot] error: ${error.message}\n`);
  process.exit(1);
});
