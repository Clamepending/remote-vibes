{
  "puzzles": [
    {
      "id": "p1_flip_h",
      "description": "Horizontal flip",
      "train": [
        {"input": [[1,0,0],[1,0,0],[1,0,0]], "output": [[0,0,1],[0,0,1],[0,0,1]]},
        {"input": [[2,2,0],[0,0,0],[0,0,0]], "output": [[0,2,2],[0,0,0],[0,0,0]]}
      ],
      "test": {"input": [[3,0,0,0],[3,3,0,0],[3,3,3,0]], "output": [[0,0,0,3],[0,0,3,3],[0,3,3,3]]}
    },
    {
      "id": "p2_rot90",
      "description": "Rotate 90 clockwise",
      "train": [
        {"input": [[1,0,0],[0,0,0],[0,0,0]], "output": [[0,0,1],[0,0,0],[0,0,0]]},
        {"input": [[1,2,0],[0,0,0],[0,0,0]], "output": [[0,0,1],[0,0,2],[0,0,0]]}
      ],
      "test": {"input": [[5,5,0],[5,0,0],[0,0,0]], "output": [[0,5,5],[0,0,5],[0,0,0]]}
    },
    {
      "id": "p3_color_swap",
      "description": "Swap all 1s with 2s (parameterized)",
      "train": [
        {"input": [[1,2,1],[2,1,2],[1,2,1]], "output": [[2,1,2],[1,2,1],[2,1,2]]},
        {"input": [[1,1,0],[2,2,0],[0,0,0]], "output": [[2,2,0],[1,1,0],[0,0,0]]}
      ],
      "test": {"input": [[1,0,2],[0,1,0],[2,0,1]], "output": [[2,0,1],[0,2,0],[1,0,2]]}
    },
    {
      "id": "p4_recolor_nonzero",
      "description": "Replace every nonzero with 4",
      "train": [
        {"input": [[1,0,0],[0,2,0],[0,0,3]], "output": [[4,0,0],[0,4,0],[0,0,4]]},
        {"input": [[5,5,0],[0,0,0],[7,0,8]], "output": [[4,4,0],[0,0,0],[4,0,4]]}
      ],
      "test": {"input": [[1,2,3],[0,0,0],[3,2,1]], "output": [[4,4,4],[0,0,0],[4,4,4]]}
    },
    {
      "id": "p5_gravity_down",
      "description": "Gravity: nonzero cells fall to the bottom of each column",
      "train": [
        {"input": [[1,0,2],[0,0,0],[0,3,0]], "output": [[0,0,0],[0,0,0],[1,3,2]]},
        {"input": [[1,1,1],[0,0,0],[0,0,0]], "output": [[0,0,0],[0,0,0],[1,1,1]]}
      ],
      "test": {"input": [[2,0,3],[0,4,0],[1,0,0]], "output": [[0,0,0],[2,0,0],[1,4,3]]}
    },
    {
      "id": "p6_symmetry_complete",
      "description": "Complete horizontal symmetry (left half mirrored to right)",
      "train": [
        {"input": [[1,0,0,0],[2,0,0,0],[3,0,0,0]], "output": [[1,0,0,1],[2,0,0,2],[3,0,0,3]]},
        {"input": [[5,6,0,0],[0,0,0,0],[7,8,0,0]], "output": [[5,6,6,5],[0,0,0,0],[7,8,8,7]]}
      ],
      "test": {"input": [[1,2,0,0],[3,0,0,0],[0,4,0,0]], "output": [[1,2,2,1],[3,0,0,3],[0,4,4,0]]}
    },
    {
      "id": "p7_flip_v",
      "description": "Vertical flip",
      "train": [
        {"input": [[1,1,1],[0,0,0],[2,2,2]], "output": [[2,2,2],[0,0,0],[1,1,1]]},
        {"input": [[3,0,0],[0,0,0],[0,0,0]], "output": [[0,0,0],[0,0,0],[3,0,0]]}
      ],
      "test": {"input": [[1,2,3],[4,5,6],[7,8,9]], "output": [[7,8,9],[4,5,6],[1,2,3]]}
    },
    {
      "id": "p8_count_fill",
      "description": "Count nonzero cells in input; output is an Nx1 column of that color",
      "train": [
        {"input": [[1,0,0],[0,1,0],[0,0,0]], "output": [[1],[1]]},
        {"input": [[2,2,0],[0,2,0],[0,0,0]], "output": [[2],[2],[2]]}
      ],
      "test": {"input": [[3,3,3],[0,0,0],[3,0,0]], "output": [[3],[3],[3],[3]]}
    }
  ]
}
